generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// CORE / AUTH / RBAC
// ─────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String?
  image         String?
  emailVerified DateTime? @map("email_verified")
  role          UserRole  @default(EMPLOYEE)
  status        UserStatus @default(ACTIVE)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  // Relations
  sessions      Session[]
  accounts      Account[]

  // Audit tracking (self-referential not used; system actions may use null)
  createdById   String?   @map("created_by_id")
  updatedById   String?   @map("updated_by_id")

  // Module relations
  leadsCreated      Lead[]        @relation("LeadCreatedBy")
  leadsUpdated      Lead[]        @relation("LeadUpdatedBy")
  leadsAssigned     Lead[]        @relation("LeadAssignedTo")
  employees         Employee[]    @relation("EmployeeUser")
  employeesCreated  Employee[]    @relation("EmployeeCreatedBy")
  employeesUpdated  Employee[]    @relation("EmployeeUpdatedBy")
  candidatesCreated Candidate[]   @relation("CandidateCreatedBy")
  candidatesUpdated Candidate[]   @relation("CandidateUpdatedBy")
  ownedProjects     Project[]     @relation("ProjectOwner")
  projectsCreated   Project[]     @relation("ProjectCreatedBy")
  projectsUpdated   Project[]     @relation("ProjectUpdatedBy")
  tasksAssigned     Task[]        @relation("TaskAssignedTo")
  tasksCreated      Task[]        @relation("TaskCreatedBy")
  tasksUpdated      Task[]        @relation("TaskUpdatedBy")
  bugsAssigned      Bug[]         @relation("BugAssignedTo")
  reportedBugs      Bug[]         @relation("BugReporter")
  bugsCreated       Bug[]         @relation("BugCreatedBy")
  bugsUpdated       Bug[]         @relation("BugUpdatedBy")
  productsCreated   Product[]     @relation("ProductCreatedBy")
  productsUpdated   Product[]     @relation("ProductUpdatedBy")
  featuresCreated   Feature[]     @relation("FeatureCreatedBy")
  featuresUpdated   Feature[]     @relation("FeatureUpdatedBy")
  releasesCreated   Release[]     @relation("ReleaseCreatedBy")
  releasesUpdated   Release[]     @relation("ReleaseUpdatedBy")
  articlesCreated   Article[]     @relation("ArticleCreatedBy")
  articlesUpdated   Article[]     @relation("ArticleUpdatedBy")
  assetsCreated     Asset[]       @relation("AssetCreatedBy")
  assetsUpdated     Asset[]       @relation("AssetUpdatedBy")
  investorsCreated  Investor[]    @relation("InvestorCreatedBy")
  investorsUpdated  Investor[]    @relation("InvestorUpdatedBy")
  vendorsCreated    Vendor[]      @relation("VendorCreatedBy")
  vendorsUpdated    Vendor[]      @relation("VendorUpdatedBy")
  partnershipsCreated Partnership[] @relation("PartnershipCreatedBy")
  partnershipsUpdated Partnership[] @relation("PartnershipUpdatedBy")
  grantsCreated     Grant[]       @relation("GrantCreatedBy")
  grantsUpdated     Grant[]       @relation("GrantUpdatedBy")
  auditLogs         AuditLog[]
  comments          Comment[]
  attachments       Attachment[]
  activities        Activity[]

  @@map("users")
  @@index([email])
  @@index([role])
  @@index([deletedAt])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
  @@index([userId])
}

model Account {
  id                String  @id @default(uuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?    @map("expires_at")
  token_type        String? @map("token_type")
  scope             String?
  id_token          String? @db.Text
  session_state     String? @map("session_state")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

enum UserRole {
  FOUNDER
  ADMIN
  HR
  SALES
  DEVELOPER
  PRODUCT_MANAGER
  EMPLOYEE
  INTERN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model AuditLog {
  id          String   @id @default(uuid())
  userId      String?  @map("user_id")
  action      String
  entityType  String   @map("entity_type")
  entityId    String   @map("entity_id")
  oldValues   Json?    @map("old_values")
  newValues   Json?    @map("new_values")
  ipAddress   String?  @map("ip_address")
  createdAt   DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────
// CORE: SHARED ENTITIES
// ─────────────────────────────────────────────────────────────

model Comment {
  id        String   @id @default(uuid())
  content   String
  entityType String  @map("entity_type")
  entityId  String   @map("entity_id")
  authorId  String   @map("author_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@map("comments")
  @@index([entityType, entityId])
  @@index([authorId])
}

model Attachment {
  id        String   @id @default(uuid())
  fileName  String   @map("file_name")
  fileUrl   String   @map("file_url")
  fileType  String?  @map("file_type")
  fileSize  Int?     @map("file_size")
  entityType String @map("entity_type")
  entityId  String   @map("entity_id")
  uploadedById String @map("uploaded_by_id")
  createdAt DateTime @default(now()) @map("created_at")

  uploadedBy User @relation(fields: [uploadedById], references: [id], onDelete: Cascade)

  @@map("attachments")
  @@index([entityType, entityId])
  @@index([uploadedById])
}

model Activity {
  id          String   @id @default(uuid())
  description String
  entityType  String   @map("entity_type")
  entityId    String   @map("entity_id")
  performedById String @map("performed_by_id")
  createdAt   DateTime @default(now()) @map("created_at")

  performedBy User @relation(fields: [performedById], references: [id], onDelete: Cascade)

  @@map("activities")
  @@index([entityType, entityId])
  @@index([performedById])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────
// MODULE 1: CRM
// ─────────────────────────────────────────────────────────────

model Lead {
  id            String     @id @default(uuid())
  companyName   String     @map("company_name")
  contactName   String     @map("contact_name")
  email         String
  phone         String?
  industry      String?
  source        String?
  value         Decimal?   @db.Decimal(12, 2)
  priority      LeadPriority @default(MEDIUM)
  notes         String?
  status        LeadStatus @default(NEW)
  assignedToId  String?    @map("assigned_to_id")
  createdById   String     @map("created_by_id")
  updatedById   String     @map("updated_by_id")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")
  deletedAt     DateTime?  @map("deleted_at")

  assignedTo  User? @relation("LeadAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdBy   User  @relation("LeadCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  updatedBy   User  @relation("LeadUpdatedBy", fields: [updatedById], references: [id], onDelete: Cascade)

  @@map("leads")
  @@index([email])
  @@index([status])
  @@index([assignedToId])
  @@index([deletedAt])
}

enum LeadStatus {
  NEW
  QUALIFIED
  MEETING_SCHEDULED
  PROPOSAL_SENT
  NEGOTIATION
  WON
  LOST
}

enum LeadPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ─────────────────────────────────────────────────────────────
// MODULE 2: HRM
// ─────────────────────────────────────────────────────────────

model Department {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  employees Employee[]

  @@map("departments")
  @@index([deletedAt])
}

model Designation {
  id          String   @id @default(uuid())
  title       String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  employees Employee[]

  @@map("designations")
  @@index([deletedAt])
}

model Employee {
  id              String          @id @default(uuid())
  employeeId      String          @unique @map("employee_id")
  userId          String?         @unique @map("user_id")
  name            String
  email           String          @unique
  phone           String?
  photo           String?
  departmentId    String?         @map("department_id")
  designationId String?         @map("designation_id")
  joiningDate     DateTime        @map("joining_date")
  employmentType  EmploymentType  @default(FULL_TIME) @map("employment_type")
  salary          Decimal?        @db.Decimal(12, 2)
  reportingManagerId String?      @map("reporting_manager_id")
  status          EmployeeStatus  @default(ACTIVE)
  createdById     String          @map("created_by_id")
  updatedById     String          @map("updated_by_id")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  deletedAt       DateTime?       @map("deleted_at")

  user              User?       @relation("EmployeeUser", fields: [userId], references: [id], onDelete: SetNull)
  department        Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  designation       Designation? @relation(fields: [designationId], references: [id], onDelete: SetNull)
  reportingManager  Employee?   @relation("ReportingManager", fields: [reportingManagerId], references: [id], onDelete: SetNull)
  reports           Employee[]  @relation("ReportingManager")
  createdBy         User        @relation("EmployeeCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  updatedBy         User        @relation("EmployeeUpdatedBy", fields: [updatedById], references: [id], onDelete: Cascade)
  leaveRequests     LeaveRequest[] @relation("LeaveRequestEmployee")
  attendances       Attendance[]
  assets            AssetAssignment[]
  ownedAssets       Asset[]        @relation("AssetOwner")

  @@map("employees")
  @@index([departmentId])
  @@index([designationId])
  @@index([reportingManagerId])
  @@index([deletedAt])
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
}

enum EmployeeStatus {
  ACTIVE
  ON_LEAVE
  TERMINATED
  RESIGNED
}

model LeaveRequest {
  id          String      @id @default(uuid())
  employeeId  String      @map("employee_id")
  leaveType   LeaveType   @map("leave_type")
  startDate   DateTime    @map("start_date")
  endDate     DateTime    @map("end_date")
  reason      String?
  status      LeaveStatus @default(PENDING)
  approvedById String?    @map("approved_by_id")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  employee    Employee @relation("LeaveRequestEmployee", fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("leave_requests")
  @@index([employeeId])
  @@index([status])
  @@index([startDate, endDate])
}

enum LeaveType {
  CASUAL
  SICK
  EARNED
  WORK_FROM_HOME
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

model Attendance {
  id          String    @id @default(uuid())
  employeeId  String    @map("employee_id")
  date        DateTime  @db.Date
  checkIn     DateTime? @map("check_in")
  checkOut    DateTime? @map("check_out")
  status      AttendanceStatus @default(PRESENT)
  note        String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@map("attendances")
  @@index([employeeId])
  @@index([date])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  WORK_FROM_HOME
}

model Holiday {
  id          String    @id @default(uuid())
  name        String
  date        DateTime  @db.Date
  description String?
  recurring   Boolean   @default(false)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("holidays")
  @@index([date])
}

// ─────────────────────────────────────────────────────────────
// MODULE 3: RECRUITMENT (ATS)
// ─────────────────────────────────────────────────────────────

model Candidate {
  id              String          @id @default(uuid())
  name            String
  email           String
  phone           String?
  resumeUrl       String?         @map("resume_url")
  portfolio       String?
  linkedIn        String?         @map("linkedin")
  positionApplied String          @map("position_applied")
  source          String?
  stage           CandidateStage  @default(APPLIED)
  score           Int?
  notes           String?
  createdById     String          @map("created_by_id")
  updatedById     String          @map("updated_by_id")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  deletedAt       DateTime?       @map("deleted_at")

  createdBy   User        @relation("CandidateCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  updatedBy   User        @relation("CandidateUpdatedBy", fields: [updatedById], references: [id], onDelete: Cascade)
  interviews  Interview[]
  scorecards  Scorecard[]

  @@unique([email, positionApplied])
  @@map("candidates")
  @@index([stage])
  @@index([positionApplied])
  @@index([deletedAt])
}

enum CandidateStage {
  APPLIED
  SCREENING
  INTERVIEW
  TECHNICAL_ROUND
  ASSIGNMENT
  OFFER
  HIRED
  REJECTED
}

model Interview {
  id          String    @id @default(uuid())
  candidateId String    @map("candidate_id")
  interviewerId String? @map("interviewer_id")
  scheduledAt DateTime  @map("scheduled_at")
  type        InterviewType @default(VIDEO)
  notes       String?
  rating      Int?
  result      InterviewResult?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@map("interviews")
  @@index([candidateId])
  @@index([scheduledAt])
}

enum InterviewType {
  PHONE
  VIDEO
  ONSITE
  PANEL
}

enum InterviewResult {
  STRONG_HIRE
  HIRE
  NO_DECISION
  NO_HIRE
  STRONG_NO_HIRE
}

model Scorecard {
  id          String   @id @default(uuid())
  candidateId String   @map("candidate_id")
  criteria    String
  score       Int
  notes       String?
  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@map("scorecards")
  @@index([candidateId])
}

// ─────────────────────────────────────────────────────────────
// MODULE 4: OPERATIONS
// ─────────────────────────────────────────────────────────────

model Investor {
  id           String    @id @default(uuid())
  name         String
  fund         String?
  email        String?
  phone        String?
  ticketSize   String?   @map("ticket_size")
  lastMeeting  DateTime? @map("last_meeting")
  nextFollowUp DateTime? @map("next_follow_up")
  notes        String?
  status       String    @default("ACTIVE")
  createdById  String    @map("created_by_id")
  updatedById  String    @map("updated_by_id")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  createdBy   User        @relation("InvestorCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  updatedBy   User        @relation("InvestorUpdatedBy", fields: [updatedById], references: [id], onDelete: Cascade)

  @@map("investors")
  @@index([deletedAt])
}

model Grant {
  id          String    @id @default(uuid())
  program     String
  organization String
  status      String    @default("APPLIED")
  amount      Decimal?  @db.Decimal(12, 2)
  deadline    DateTime?
  documents   Json?
  notes       String?
  createdById String    @map("created_by_id")
  updatedById String    @map("updated_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  createdBy   User        @relation("GrantCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  updatedBy   User        @relation("GrantUpdatedBy", fields: [updatedById], references: [id], onDelete: Cascade)

  @@map("grants")
  @@index([status])
  @@index([deletedAt])
}

model Partnership {
  id           String    @id @default(uuid())
  organization String
  contactName  String?   @map("contact_name")
  contactEmail String?   @map("contact_email")
  contactPhone String?   @map("contact_phone")
  status       String    @default("DISCUSSION")
  type         String?
  notes        String?
  createdById  String    @map("created_by_id")
  updatedById  String    @map("updated_by_id")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  createdBy   User        @relation("PartnershipCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  updatedBy   User        @relation("PartnershipUpdatedBy", fields: [updatedById], references: [id], onDelete: Cascade)

  @@map("partnerships")
  @@index([status])
  @@index([deletedAt])
}

model Vendor {
  id           String    @id @default(uuid())
  name         String
  service      String?
  contactName  String?   @map("contact_name")
  contactEmail String?   @map("contact_email")
  contactPhone String?   @map("contact_phone")
  contractUrl  String?   @map("contract_url")
  renewalDate  DateTime? @map("renewal_date")
  status       String    @default("ACTIVE")
  notes        String?
  createdById  String    @map("created_by_id")
  updatedById  String    @map("updated_by_id")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  createdBy   User        @relation("VendorCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  updatedBy   User        @relation("VendorUpdatedBy", fields: [updatedById], references: [id], onDelete: Cascade)

  @@map("vendors")
  @@index([status])
  @@index([deletedAt])
}

// ─────────────────────────────────────────────────────────────
// MODULE 5: PROJECT MANAGEMENT
// ─────────────────────────────────────────────────────────────

model Project {
  id          String        @id @default(uuid())
  name        String
  description String?
  ownerId     String        @map("owner_id")
  status      ProjectStatus @default(PLANNING)
  priority    ProjectPriority @default(MEDIUM)
  startDate   DateTime?     @map("start_date")
  deadline    DateTime?
  createdById String        @map("created_by_id")
  updatedById String        @map("updated_by_id")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  deletedAt   DateTime?     @map("deleted_at")

  owner       User        @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  createdBy   User        @relation("ProjectCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  updatedBy   User        @relation("ProjectUpdatedBy", fields: [updatedById], references: [id], onDelete: Cascade)
  sprints     Sprint[]
  tasks       Task[]

  @@map("projects")
  @@index([status])
  @@index([ownerId])
  @@index([deletedAt])
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum ProjectPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model Sprint {
  id          String    @id @default(uuid())
  projectId   String    @map("project_id")
  name        String
  goal        String?
  startDate   DateTime  @map("start_date")
  endDate     DateTime  @map("end_date")
  status      SprintStatus @default(PLANNING)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]
  features Feature[]

  @@map("sprints")
  @@index([projectId])
}

enum SprintStatus {
  PLANNING
  ACTIVE
  COMPLETED
}

model Task {
  id          String     @id @default(uuid())
  title       String
  description String?
  priority    TaskPriority @default(MEDIUM)
  status      TaskStatus @default(BACKLOG)
  assigneeId  String?    @map("assignee_id")
  projectId   String     @map("project_id")
  sprintId    String?    @map("sprint_id")
  releaseId   String?    @map("release_id")
  dueDate     DateTime?  @map("due_date")
  parentId    String?    @map("parent_id")
  createdById String     @map("created_by_id")
  updatedById String     @map("updated_by_id")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  deletedAt   DateTime?  @map("deleted_at")

  assignee    User?     @relation("TaskAssignedTo", fields: [assigneeId], references: [id], onDelete: SetNull)
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sprint      Sprint?   @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  release     Release?  @relation(fields: [releaseId], references: [id], onDelete: SetNull)
  createdBy   User      @relation("TaskCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  updatedBy   User      @relation("TaskUpdatedBy", fields: [updatedById], references: [id], onDelete: Cascade)
  parent      Task?     @relation("TaskSubtasks", fields: [parentId], references: [id], onDelete: SetNull)
  subtasks    Task[]    @relation("TaskSubtasks")
  dependencies TaskDependency[]
  dependents  TaskDependency[] @relation("TaskDependents")

  @@map("tasks")
  @@index([projectId])
  @@index([sprintId])
  @@index([releaseId])
  @@index([assigneeId])
  @@index([status])
  @@index([deletedAt])
}

enum TaskStatus {
  BACKLOG
  TO_DO
  IN_PROGRESS
  REVIEW
  TESTING
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model TaskDependency {
  id          String @id @default(uuid())
  taskId      String @map("task_id")
  dependsOnId String @map("depends_on_id")
  type        DependencyType @default(BLOCKS)

  task      Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  dependsOn Task @relation("TaskDependents", fields: [dependsOnId], references: [id], onDelete: Cascade)

  @@unique([taskId, dependsOnId])
  @@map("task_dependencies")
}

enum DependencyType {
  BLOCKS
  RELATES_TO
  DUPLICATES
}

// ─────────────────────────────────────────────────────────────
// MODULE 6: PRODUCT MANAGEMENT
// ─────────────────────────────────────────────────────────────

model Product {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  status      String    @default("ACTIVE")
  createdById String    @map("created_by_id")
  updatedById String    @map("updated_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  createdBy   User        @relation("ProductCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  updatedBy   User        @relation("ProductUpdatedBy", fields: [updatedById], references: [id], onDelete: Cascade)
  features    Feature[]
  releases    Release[]
  bugs        Bug[]

  @@map("products")
  @@index([deletedAt])
}

model Platform {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  featureStatuses FeatureStatus[]

  @@map("platforms")
}

model Feature {
  id          String    @id @default(uuid())
  name        String
  description String?
  productId   String    @map("product_id")
  priority    FeaturePriority @default(MEDIUM)
  releaseId   String?   @map("release_id")
  sprintId    String?   @map("sprint_id")
  createdById String    @map("created_by_id")
  updatedById String    @map("updated_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  product         Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  release         Release?        @relation(fields: [releaseId], references: [id], onDelete: SetNull)
  sprint          Sprint?         @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  createdBy       User            @relation("FeatureCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  updatedBy       User            @relation("FeatureUpdatedBy", fields: [updatedById], references: [id], onDelete: Cascade)
  subFeatures     SubFeature[]
  platformStatuses FeatureStatus[]

  @@map("features")
  @@index([productId])
  @@index([releaseId])
  @@index([deletedAt])
}

enum FeaturePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model SubFeature {
  id          String    @id @default(uuid())
  name        String
  description String?
  featureId   String    @map("feature_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  feature         Feature         @relation(fields: [featureId], references: [id], onDelete: Cascade)
  platformStatuses FeatureStatus[]

  @@map("sub_features")
  @@index([featureId])
  @@index([deletedAt])
}

model FeatureStatus {
  id            String          @id @default(uuid())
  featureId     String?         @map("feature_id")
  subFeatureId  String?         @map("sub_feature_id")
  platformId    String          @map("platform_id")
  status        PlatformStatus  @default(NOT_STARTED)
  notes         String?
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  feature    Feature?    @relation(fields: [featureId], references: [id], onDelete: Cascade)
  subFeature SubFeature? @relation(fields: [subFeatureId], references: [id], onDelete: Cascade)
  platform   Platform    @relation(fields: [platformId], references: [id], onDelete: Cascade)

  @@unique([featureId, subFeatureId, platformId])
  @@map("feature_statuses")
  @@index([featureId])
  @@index([subFeatureId])
  @@index([platformId])
}

enum PlatformStatus {
  NOT_STARTED
  PLANNED
  IN_PROGRESS
  TESTING
  BLOCKED
  DONE
}

// ─────────────────────────────────────────────────────────────
// MODULE 7: BUG TRACKING
// ─────────────────────────────────────────────────────────────

model Bug {
  id          String      @id @default(uuid())
  bugId       String      @unique @map("bug_id")
  title       String
  description String?
  severity    BugSeverity @default(MINOR)
  priority    BugPriority @default(MEDIUM)
  platform    String?
  productId   String?     @map("product_id")
  releaseId   String?     @map("release_id")
  version     String?
  assigneeId  String?     @map("assignee_id")
  reporterId  String      @map("reporter_id")
  status      BugStatus   @default(OPEN)
  steps       String?
  createdById String      @map("created_by_id")
  updatedById String      @map("updated_by_id")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  deletedAt   DateTime?   @map("deleted_at")

  assignee    User?       @relation("BugAssignedTo", fields: [assigneeId], references: [id], onDelete: SetNull)
  reporter    User        @relation("BugReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  createdBy   User        @relation("BugCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  updatedBy   User        @relation("BugUpdatedBy", fields: [updatedById], references: [id], onDelete: Cascade)
  product     Product?    @relation(fields: [productId], references: [id], onDelete: SetNull)
  release     Release?    @relation(fields: [releaseId], references: [id], onDelete: SetNull)

  @@map("bugs")
  @@index([status])
  @@index([severity])
  @@index([assigneeId])
  @@index([productId])
  @@index([releaseId])
  @@index([deletedAt])
}

enum BugSeverity {
  CRITICAL
  MAJOR
  MINOR
  TRIVIAL
}

enum BugPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum BugStatus {
  OPEN
  INVESTIGATING
  IN_PROGRESS
  TESTING
  RESOLVED
  CLOSED
}

// ─────────────────────────────────────────────────────────────
// MODULE 8: RELEASE MANAGEMENT
// ─────────────────────────────────────────────────────────────

model Release {
  id          String        @id @default(uuid())
  version     String
  name        String
  productId   String        @map("product_id")
  releaseDate DateTime?     @map("release_date")
  status      ReleaseStatus @default(PLANNING)
  notes       String?
  createdById String        @map("created_by_id")
  updatedById String        @map("updated_by_id")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  deletedAt   DateTime?     @map("deleted_at")

  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdBy   User        @relation("ReleaseCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  updatedBy   User        @relation("ReleaseUpdatedBy", fields: [updatedById], references: [id], onDelete: Cascade)
  features    Feature[]
  bugs        Bug[]
  tasks       Task[]
  releaseNotes ReleaseNote[]

  @@unique([version, productId])
  @@map("releases")
  @@index([productId])
  @@index([status])
  @@index([deletedAt])
}

enum ReleaseStatus {
  PLANNING
  DEVELOPMENT
  QA
  RELEASED
}

model ReleaseNote {
  id        String   @id @default(uuid())
  releaseId String   @map("release_id")
  category  String   @default("GENERAL")
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  release Release @relation(fields: [releaseId], references: [id], onDelete: Cascade)

  @@map("release_notes")
  @@index([releaseId])
}

// ─────────────────────────────────────────────────────────────
// MODULE 9: KNOWLEDGE BASE
// ─────────────────────────────────────────────────────────────

model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  parentId    String?   @map("parent_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  parent   Category? @relation("CategoryParent", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("CategoryParent")
  articles Article[]

  @@map("categories")
  @@index([deletedAt])
}

model Article {
  id          String    @id @default(uuid())
  title       String
  slug        String    @unique
  content     String
  summary     String?
  categoryId  String    @map("category_id")
  tags        String[]
  status      ArticleStatus @default(DRAFT)
  version     Int       @default(1)
  createdById String    @map("created_by_id")
  updatedById String    @map("updated_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  category  Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdBy User        @relation("ArticleCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  updatedBy User        @relation("ArticleUpdatedBy", fields: [updatedById], references: [id], onDelete: Cascade)
  versions  ArticleVersion[]

  @@map("articles")
  @@index([categoryId])
  @@index([status])
  @@index([deletedAt])
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model ArticleVersion {
  id        String   @id @default(uuid())
  articleId String   @map("article_id")
  content   String
  version   Int
  createdById String @map("created_by_id")
  createdAt DateTime @default(now()) @map("created_at")

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@map("article_versions")
  @@index([articleId])
}

// ─────────────────────────────────────────────────────────────
// MODULE 10: ASSET MANAGEMENT
// ─────────────────────────────────────────────────────────────

model AssetCategory {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  assets Asset[]

  @@map("asset_categories")
}

model Asset {
  id            String    @id @default(uuid())
  name          String
  type          String
  assetCategoryId String  @map("asset_category_id")
  ownerId       String?   @map("owner_id")
  value         Decimal?  @db.Decimal(12, 2)
  purchaseDate  DateTime? @map("purchase_date")
  expiryDate    DateTime? @map("expiry_date")
  renewalDate   DateTime? @map("renewal_date")
  status        AssetStatus @default(ACTIVE)
  notes         String?
  createdById   String    @map("created_by_id")
  updatedById   String    @map("updated_by_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  category    AssetCategory     @relation(fields: [assetCategoryId], references: [id], onDelete: Cascade)
  owner       Employee?         @relation("AssetOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  createdBy   User              @relation("AssetCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  updatedBy   User              @relation("AssetUpdatedBy", fields: [updatedById], references: [id], onDelete: Cascade)
  assignments AssetAssignment[]

  @@map("assets")
  @@index([assetCategoryId])
  @@index([status])
  @@index([expiryDate])
  @@index([deletedAt])
}

enum AssetStatus {
  ACTIVE
  EXPIRED
  IN_MAINTENANCE
  DISPOSED
}

model AssetAssignment {
  id          String    @id @default(uuid())
  assetId     String    @map("asset_id")
  employeeId  String    @map("employee_id")
  assignedAt  DateTime  @default(now()) @map("assigned_at")
  returnedAt  DateTime? @map("returned_at")
  condition   String?

  asset    Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("asset_assignments")
  @@index([assetId])
  @@index([employeeId])
}

// ─────────────────────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────────────────────

model Notification {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  title       String
  body        String?
  entityType  String?   @map("entity_type")
  entityId    String?   @map("entity_id")
  read        Boolean   @default(false)
  channel     NotificationChannel @default(IN_APP)
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("notifications")
  @@index([userId])
  @@index([read])
  @@index([createdAt])
}

enum NotificationChannel {
  IN_APP
  EMAIL
  PUSH
}
